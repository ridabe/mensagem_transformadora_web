# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the anonymous/public key or the publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL connection string (server-side)
CONNECTION_STRING=postgresql://user:password@host:port/database

# URL configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
URL_SITE=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=localhost:3000
VERCEL_URL=localhost:3000

# Optional app settings
MT_BOOTSTRAP_ADMIN_AUTH_USER_ID=your-admin-auth-user-id
MT_PAST_DUE_GRACE_DAYS=3

# AbacatePay (payments)
ABACATEPAY_API_KEY=your-abacatepay-api-key
ABACATEPAY_BASIC_PRODUCT_ID=your-basic-product-id
ABACATEPAY_PRO_PRODUCT_ID=your-pro-product-id
ABACATEPAY_WEBHOOK_SECRET
